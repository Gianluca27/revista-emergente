# server/.env — copiar a server/.env y completar valores

PORT=3001
NODE_ENV=development

DATABASE_URL=postgresql://emergente_user:PASSWORD@localhost:5432/emergente_db

JWT_SECRET=<random-64-chars-min>
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173

UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Opcional — notificaciones email
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=admin@revistaemergente.ar
